                              </form>
                              <script type="text/javascript"> 
                                  function submit() {
                                    var jcurl = window.location.href;
                                    document.getElementById('jcurl').value = jcurl;
                                    var mform = document.getElementById('jcmyform');
                                    mform.action='http://130.9.1.168/feedback/pub/index.jsp';
                                    mform.submit();
                                   }
                               </script>
                                <!--<div class="jcjy">
                                    <a href="" target="_blank">纠错或建议</a>
                                </div>-->
                            </div>
                        </div>
                    </body></html>
